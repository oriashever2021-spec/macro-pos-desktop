{
  "name": "macro-pos-desktop",
  "version": "1.0.3",
  "description": "Macrobiótica Eccos POS — desktop wrapper (loads myposcr.web.app)",
  "main": "main.js",
  "author": "Macrobiótica Eccos",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "release": "npm version patch && git push && git push --tags"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "^2.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cr.eccos.pos",
    "productName": "Macrobiótica Eccos POS",
    "afterPack": "./afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "oriashever2021-spec",
        "repo": "macro-pos-desktop"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/icon.png"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Macrobiótica Eccos POS",
      "artifactName": "MacrobioticaEccosPOS-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
